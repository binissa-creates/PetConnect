{
  "name": "petconnect-main",
  "version": "1.0.0",
  "scripts": {
    "install-all": "npm.cmd install && cd frontend && npm.cmd install && cd ../backend && npm.cmd install",
    "dev": "concurrently \"npm.cmd run backend\" \"npm.cmd run frontend\"",
    "frontend": "cd frontend && npm.cmd run dev",
    "backend": "cd backend && node index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
